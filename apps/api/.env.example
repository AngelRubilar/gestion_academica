# --- Server ---
NODE_ENV=development
PORT=3001

# --- Database ---
DATABASE_URL=postgresql://gestion_academica:devpassword@localhost:5432/gestion_academica

# --- CORS (lista separada por coma de orígenes permitidos) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- JWT (el secreto debe tener mínimo 32 caracteres; expiraciones en formato jsonwebtoken: 15m, 7d, 1h) ---
JWT_SECRET=cambiar-por-secreto-de-32-chars-minimo-en-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Rate limiting (ventana en milisegundos, máximo de requests por ventana) ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# --- Observabilidad ---
LOG_LEVEL=info        # fatal | error | warn | info | debug | trace
SWAGGER_ENABLED=true  # sirve /api/docs (usar 'false' en producción si se quiere ocultar)
