# ===========================================
# Configuración de la instancia del colegio
# ===========================================

# Nombre del colegio
SCHOOL_NAME=Mi Colegio

# ===========================================
# Base de datos - PostgreSQL
# ===========================================
POSTGRES_USER=gestion_academica
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
POSTGRES_DB=gestion_academica
DATABASE_URL=postgresql://gestion_academica:CAMBIAR_EN_PRODUCCION@postgres:5432/gestion_academica

# ===========================================
# Redis
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ===========================================
# API - NestJS
# ===========================================
API_PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=CAMBIAR_EN_PRODUCCION_USAR_STRING_LARGO_ALEATORIO
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===========================================
# Web - Next.js
# ===========================================
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://tu-dominio.cl/api

# ===========================================
# MinIO - Almacenamiento de archivos
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=gestion-academica
MINIO_USE_SSL=false

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CAMBIAR
SMTP_FROM=noreply@example.com

# ===========================================
# Firebase (Push Notifications)
# ===========================================
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
